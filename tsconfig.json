{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    /* node ではなく bundler または node16/nodenext を推奨 */
    "moduleResolution": "bundler", 
    "esModuleInterop": true,
    "strict": true,
    /* 1. ソースコードの場所を明示（TS5011対策） */
    "rootDir": "./src", 
    /* 2. 出力先の場所 */
    "outDir": "./dist",
    /* 3. 古い設定に対する警告を消す（必要に応じて） */
    "skipLibCheck": true
  },
  /* コンパイル対象をsrcフォルダ内に限定 */
  "include": ["src/**/*"]
}